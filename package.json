{
  "name": "adaptive-card",
  "version": "0.0.1",
  "description": "generate validated adaptive card and send it to webhook",
  "engines": { "node": ">=22" },
  "type": "module",
  "main": "lib/src/index.js",
  "files": [
    "lib/src"
  ],
  "bin": {
    "adaptive-card": "lib/bin/adaptive-card"
  },
  "scripts": {
    "prelint": "rm -rf lib",
    "lint": "eslint src test",
    "prebuild": "npm run lint",
    "build": "tsc && cp assets/adaptive-card-schema.json lib/src/ && mkdir -p lib/bin && sed 's|../lib/src/cli.js|../src/cli.js|' bin/adaptive-card > lib/bin/adaptive-card && chmod +x lib/bin/adaptive-card",
    "pretest": "npm run build",
    "test": "node --test 'lib/test/**/*.test.js'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "adaptive",
    "card",
    "webhook"
  ],
  "author": "sylvainrivierre@gmail.com",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
